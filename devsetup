# =============================================================================
# в”Җв”Җ Config loader в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# =============================================================================
declare -A TOOL_GROUPS=()

_load_tools_conf() {
    [[ ${#TOOL_GROUPS[@]} -gt 0 ]] && return 0   # already loaded
    local conf="$CONF_DIR/tools.conf"
    if [[ ! -f "$conf" ]]; then
        log_warn "tools.conf not found at $conf"; return
    fi
    while IFS=: read -r category tool || [[ -n "$tool" ]]; do
        [[ -z "$category" || "$category" =~ ^# || -z "$tool" ]] && continue
        category="${category// /}"
        tool="${tool// /}"
        TOOL_GROUPS["$category"]+="$tool "
    done < <(grep -v '^\s*#' "$conf" | grep -v '^\s*$')
}

# =============================================================================
# в”Җв”Җ Git configuration wizard в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# =============================================================================
run_git_config_wizard() {
    log_section "Git Configuration Wizard"

    local cur_name;  cur_name="$(git config --global user.name  2>/dev/null || echo '')"
    local cur_email; cur_email="$(git config --global user.email 2>/dev/null || echo '')"
    local cur_branch; cur_branch="$(git config --global init.defaultBranch 2>/dev/null || echo 'main')"
    local cur_editor; cur_editor="$(git config --global core.editor 2>/dev/null || echo 'vim')"

    echo >&2
    local git_name;   git_name="$(tui_read "Full name"             "$cur_name")"
    local git_email;  git_email="$(tui_read "Email"                "$cur_email")"
    local git_branch; git_branch="$(tui_read "Default branch"      "$cur_branch")"
    local git_editor; git_editor="$(tui_read "Preferred editor"    "$cur_editor")"
    echo >&2

    echo -e "  ${DIM}Settings preview:${RESET}" >&2
    printf "  %-22s ${TEAL}%s${RESET}\n" "user.name"           "$git_name"   >&2
    printf "  %-22s ${TEAL}%s${RESET}\n" "user.email"          "$git_email"  >&2
    printf "  %-22s ${TEAL}%s${RESET}\n" "init.defaultBranch"  "$git_branch" >&2
    printf "  %-22s ${TEAL}%s${RESET}\n" "core.editor"         "$git_editor" >&2
    echo >&2

    tui_confirm "Apply these Git settings?" || { log_skip "Git config cancelled."; return 0; }

    run_cmd git config --global user.name              "$git_name"
    run_cmd git config --global user.email             "$git_email"
    run_cmd git config --global init.defaultBranch     "$git_branch"
    run_cmd git config --global core.editor            "$git_editor"
    run_cmd git config --global core.autocrlf          input
    run_cmd git config --global pull.rebase            true
    run_cmd git config --global push.autoSetupRemote   true
    run_cmd git config --global rerere.enabled         true
    run_cmd git config --global color.ui               auto
    run_cmd git config --global alias.lg  "log --oneline --graph --decorate -20"
    run_cmd git config --global alias.st  "status -sb"
    run_cmd git config --global alias.undo "reset HEAD~1 --mixed"

    log_ok "Git configured."
}

# =============================================================================
# в”Җв”Җ Install list with step counter в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# =============================================================================
install_tool_list() {
    local -a tools=("$@")
    local total="${#tools[@]}" n=0

    _pkg_update

    for tool in "${tools[@]}"; do
        (( n++ ))
        log_progress "$n" "$total" "$tool"
        install_tool "$tool" || true
    done

    echo >&2
    log_summary
}

# =============================================================================
# в”Җв”Җ --list display в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# =============================================================================
_print_list() {
    _load_tools_conf
    declare -A CAT_COLORS=(
        [DevOps]="$TEAL"     [IaC]="$ORANGE"    [Cloud]="$INDIGO"
        [WebServer]="$LIME"  [PHP]="$LAVENDER"  [Database]="$CORAL"
        [Languages]="$YELLOW" [VCS]="$BCYAN"    [Utils]="$PINK"
    )
    declare -A CAT_ICONS=(
        [DevOps]="вҺҲ" [IaC]="вӣҢ" [Cloud]="вҳҒ"  [WebServer]="рҹҢҗ" [PHP]="О»"
        [Database]="в–Ј" [Languages]="вҹЁ/вҹ©" [VCS]="в‘Ӯ" [Utils]="вҡ’"
    )
    local total_tools=0 installed_tools=0
    local sorted_cats; sorted_cats="$(echo "${!TOOL_GROUPS[*]}" | tr ' ' '\n' | sort)"
    while IFS= read -r cat; do
        local color="${CAT_COLORS[$cat]:-$TEAL}"
        local icon="${CAT_ICONS[$cat]:- }"
        printf "\n  ${color}${BOLD}${BG_DARK}  %s %s  ${RESET}\n" "$icon" "$cat" >&2
        for tool in ${TOOL_GROUPS[$cat]}; do
            (( total_tools++ ))
            if command -v "$tool" &>/dev/null; then
                (( installed_tools++ ))
                printf "    ${BGREEN}${ICON_OK}${RESET}  ${GREEN}%-18s${RESET}  ${DIM}%s${RESET}\n" \
                    "$tool" "$(command -v "$tool")" >&2
            else
                printf "    ${DIM}в—Ұ${RESET}  ${DIM}%-18s${RESET}\n" "$tool" >&2
            fi
        done
    done <<< "$sorted_cats"
    echo >&2
    printf "  ${DIM}%d / %d installed${RESET}  ${DIM}в”Ӯ  devsetup --install TOOL to add more${RESET}\n\n" \
        "$installed_tools" "$total_tools" >&2
}

# =============================================================================
# в”Җв”Җ Interactive TUI в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# =============================================================================
run_interactive() {
    _load_tools_conf
    detect_os
    _print_banner

    # Brief non-blocking doctor
    log_section "Pre-flight"
    check_internet || log_warn "Internet offline вҖ” installs will fail."
    check_sudo; check_disk_space /; check_pkg_lock
    echo >&2

    # Temp file: all TUI backends write their selection here directly (no subshell tricks)
    _tui_out_file="$(mktemp /tmp/devsetup_sel.XXXXXX)"
    export _tui_out_file

    if ! tui_select_tools TOOL_GROUPS; then
        log_info "No tools selected. Exiting."
        rm -f "$_tui_out_file"; unset _tui_out_file
        exit 0
    fi

    local selected_raw; selected_raw="$(cat "$_tui_out_file" 2>/dev/null || echo '')"
    rm -f "$_tui_out_file"; unset _tui_out_file

    local -a selected_tools=()
    [[ -n "${selected_raw// /}" ]] && IFS=' ' read -ra selected_tools <<< "$selected_raw"

    if [[ ${#selected_tools[@]} -eq 0 ]]; then
        log_info "No tools selected. Exiting."; exit 0
    fi

    log_section "Installing: ${selected_tools[*]}"

    if printf '%s\n' "${selected_tools[@]}" | grep -qi '^git$'; then
        tui_confirm "Run the Git configuration wizard?" && run_git_config_wizard
    fi

    install_tool_list "${selected_tools[@]}"

    tui_confirm "Inject DevOps shell aliases into your RC file?" \
        && inject_aliases "$CONF_DIR/aliases.conf"

    tui_confirm "Scaffold a DevOps project folder structure?" \
        && scaffold_interactive "$CONF_DIR/folders.conf"

    printf "\n" >&2
    log_section "All done рҹҡҖ"
    log_ok "Open a new terminal or run: source ~/.bashrc"
    log_info "Full log: $LOG_FILE"
}

# =============================================================================
# в”Җв”Җ Entrypoint в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# =============================================================================
main() {
    detect_os
    _acquire_lock

    [[ $# -eq 0 ]] && { run_interactive; exit 0; }

    case "$1" in
        --help|-h)    _print_help ;;
        --version)    echo "devsetup $DEVSETUP_VERSION" ;;

        --doctor)
            _print_banner
            run_doctor
            ;;

        --status)
            _print_banner
            _load_tools_conf
            show_status
            ;;

        --list)
            _print_banner
            _print_list
            ;;

        --dry-run)
            DRY_RUN=true; export DRY_RUN
            log_warn "DRY RUN вҖ” no changes will be made."
            shift
            if [[ $# -gt 0 ]]; then main "$@"
            else run_interactive; fi
            ;;

        --install)
            shift
            [[ $# -eq 0 ]] && { log_error "--install needs at least one tool name."; exit 1; }
            _print_banner
            log_section "Installing: $*"
            check_internet 2>/dev/null || log_warn "No internet вҖ” installs may fail."
            install_tool_list "$@"
            ;;

        --update)
            shift
            [[ $# -eq 0 ]] && { log_error "--update needs at least one tool name."; exit 1; }
            _print_banner
            log_section "Updating: $*"
            local -a _tools=("$@"); local _total="${#_tools[@]}" _n=0
            _pkg_update
            for _tool in "${_tools[@]}"; do
                (( _n++ ))
                log_progress "$_n" "$_total" "Updating $_tool"
                local _body_fn="_install_${_tool,,}_body"
                local _install_fn="install_${_tool,,}"
                if declare -f "$_body_fn" >/dev/null; then
                    spinner_start "Updating $_tool"
                    _do_install "$_tool" "$_body_fn" \
                        && { _installed_ok "$_tool updated."; summary_ok "$_tool updated"; } \
                        || summary_fail "$_tool"
                elif declare -f "$_install_fn" >/dev/null; then
                    "$_install_fn" || true
                else
                    log_error "No updater for: $_tool"; summary_fail "$_tool (unknown)"
                fi
            done
            echo >&2; log_summary
            ;;

        --uninstall)
            shift
            [[ $# -eq 0 ]] && { log_error "--uninstall needs at least one tool name."; exit 1; }
            _print_banner
            log_section "Uninstalling: $*"
            tui_confirm "Remove ${*}? This cannot be undone." \
                || { log_skip "Uninstall cancelled."; exit 0; }
            local _tools=("$@"); local _total="${#_tools[@]}" _n=0
            for _tool in "${_tools[@]}"; do
                (( _n++ ))
                log_progress "$_n" "$_total" "Removing $_tool"
                uninstall_tool "$_tool" || log_warn "Could not fully remove $_tool"
            done
            echo >&2; log_summary
            ;;

        --git-config)  run_git_config_wizard ;;
        --aliases)     inject_aliases "$CONF_DIR/aliases.conf" ;;
        --remove-aliases) remove_aliases ;;
        --preview-aliases) preview_aliases "$CONF_DIR/aliases.conf" ;;

        --scaffold)
            shift
            if [[ -n "${1:-}" ]]; then
                scaffold_project "$CONF_DIR/folders.conf" "$HOME/projects/$1"
            else
                scaffold_interactive "$CONF_DIR/folders.conf"
            fi
            ;;

        --preview-scaffold) preview_scaffold "$CONF_DIR/folders.conf" ;;

        *)
            log_error "Unknown option: $1"
            echo -e "  ${DIM}Run 'devsetup --help' for usage.${RESET}" >&2
            exit 1
            ;;
    esac
}

main "$@"

}

# =============================================================================
# ── Config loader ─────────────────────────────────────────────────────────────
# =============================================================================
declare -A TOOL_GROUPS=()

_load_tools_conf() {
    local conf="$CONF_DIR/tools.conf"
    [[ ! -f "$conf" ]] && { log_warn "tools.conf not found at $conf"; return; }
    while IFS=: read -r category tool || [[ -n "$tool" ]]; do
        [[ -z "$category" || "$category" =~ ^# || -z "$tool" ]] && continue
        TOOL_GROUPS["$category"]+="${tool// /} "
    done < <(grep -v '^\s*#' "$conf" | grep -v '^\s*$')
}

# =============================================================================
# ── Git configuration wizard ─────────────────────────────────────────────────
# =============================================================================
run_git_config_wizard() {
    log_section "Git Configuration Wizard"

    local cur_name;  cur_name="$(git config --global user.name  2>/dev/null || echo '')"
    local cur_email; cur_email="$(git config --global user.email 2>/dev/null || echo '')"
    local cur_branch; cur_branch="$(git config --global init.defaultBranch 2>/dev/null || echo 'main')"
    local cur_editor; cur_editor="$(git config --global core.editor 2>/dev/null || echo 'vim')"

    echo -e "" >&2
    local git_name;   git_name="$(tui_read  "Full name"        "$cur_name")"
    local git_email;  git_email="$(tui_read "Email"            "$cur_email")"
    local git_branch; git_branch="$(tui_read "Default branch"  "$cur_branch")"
    local git_editor; git_editor="$(tui_read "Preferred editor" "$cur_editor")"
    echo -e "" >&2

    echo -e "  ${DIM}Preview:${RESET}" >&2
    printf "  %-18s ${TEAL}%s${RESET}\n" "user.name"        "$git_name"   >&2
    printf "  %-18s ${TEAL}%s${RESET}\n" "user.email"       "$git_email"  >&2
    printf "  %-18s ${TEAL}%s${RESET}\n" "init.defaultBranch" "$git_branch" >&2
    printf "  %-18s ${TEAL}%s${RESET}\n" "core.editor"      "$git_editor" >&2
    echo -e "" >&2

    if ! tui_confirm "Apply these Git settings?"; then
        log_skip "Git configuration cancelled."; return 0
    fi

    run_cmd git config --global user.name           "$git_name"
    run_cmd git config --global user.email          "$git_email"
    run_cmd git config --global init.defaultBranch  "$git_branch"
    run_cmd git config --global core.editor         "$git_editor"
    run_cmd git config --global core.autocrlf       input
    run_cmd git config --global pull.rebase         true
    run_cmd git config --global push.autoSetupRemote true
    run_cmd git config --global rerere.enabled      true
    run_cmd git config --global color.ui            auto
    run_cmd git config --global alias.lg            "log --oneline --graph --decorate -20"
    run_cmd git config --global alias.st            "status -sb"
    run_cmd git config --global alias.undo          "reset HEAD~1 --mixed"

    log_ok "Git configured successfully."
}

# =============================================================================
# ── Install tool list with progress ──────────────────────────────────────────
# =============================================================================
install_tool_list() {
    local tools=("$@")
    local total="${#tools[@]}"
    local n=0

    _pkg_update

    for tool in "${tools[@]}"; do
        (( n++ ))
        log_progress "$n" "$total" "$tool"
        install_tool "$tool" || true  # failures tracked via summary_fail
    done

    echo -e "" >&2
    log_summary
}

# =============================================================================
# ── Interactive TUI mode ──────────────────────────────────────────────────────
# =============================================================================
run_interactive() {
    _load_tools_conf
    detect_os

    _print_banner
    log_section "System Information"
    detect_print_summary
    echo -e "" >&2

    # Run doctor in brief mode
    log_section "Pre-flight Check"
    if ! check_internet; then
        if ! tui_confirm "Internet appears offline. Continue anyway?"; then exit 0; fi
    fi
    check_sudo; check_disk_space /; check_pkg_lock
    echo -e "" >&2

    local selected_raw
    if ! selected_raw="$(tui_select_tools TOOL_GROUPS 2>/dev/tty)"; then
        log_info "No tools selected. Exiting."; exit 0
    fi

    local -a selected_tools=()
    read -ra selected_tools <<< "$selected_raw"

    if [[ ${#selected_tools[@]} -eq 0 ]]; then
        log_info "No tools selected. Exiting."; exit 0
    fi

    log_section "Installing Selected Tools"
    log_info "Selected: ${selected_tools[*]}"

    if printf '%s\n' "${selected_tools[@]}" | grep -qi '^git$'; then
        if tui_confirm "Run the Git configuration wizard?"; then
            run_git_config_wizard
        fi
    fi

    install_tool_list "${selected_tools[@]}"

    if tui_confirm "Inject devsetup shell aliases into your RC file?"; then
        inject_aliases "$CONF_DIR/aliases.conf"
    fi

    if tui_confirm "Scaffold a new DevOps project folder structure?"; then
        scaffold_interactive "$CONF_DIR/folders.conf"
    fi

    echo -e "" >&2
    log_section "Done! 🚀"
    log_ok "Open a new terminal or run: source ~/.bashrc"
    log_info "Log saved to: $LOG_FILE"
}

# =============================================================================
# ── Entrypoint ────────────────────────────────────────────────────────────────
# =============================================================================
main() {
    detect_os
    _acquire_lock

    if [[ $# -eq 0 ]]; then
        run_interactive; exit 0
    fi

    case "$1" in
        --help|-h)
            _print_help
            ;;

        --version)
            echo "devsetup $DEVSETUP_VERSION"
            ;;

        --doctor)
            _print_banner
            run_doctor
            ;;

        --status)
            detect_os
            _print_banner
            _load_tools_conf
            show_status
            ;;

        --list)
            _print_banner
            _load_tools_conf

            declare -A CAT_COLORS=(
                [DevOps]="$TEAL"     [IaC]="$ORANGE"    [Cloud]="$INDIGO"
                [WebServer]="$LIME"  [PHP]="$LAVENDER"  [Database]="$CORAL"
                [Languages]="$YELLOW" [VCS]="$BCYAN"   [Utils]="$PINK"
            )
            declare -A CAT_ICONS=(
                [DevOps]="⎈" [IaC]="⛌" [Cloud]="☁"  [WebServer]="🌐" [PHP]="λ"
                [Database]="▣" [Languages]="⟨/⟩" [VCS]="⑂" [Utils]="⚒"
            )
            local total_tools=0 installed_tools=0
            local sorted_cats; sorted_cats="$(echo "${!TOOL_GROUPS[*]}" | tr ' ' '\n' | sort)"
            while IFS= read -r cat; do
                local color="${CAT_COLORS[$cat]:-$TEAL}"
                local icon="${CAT_ICONS[$cat]:- }"
                printf "\n  ${color}${BOLD}${BG_DARK}  %s %s  ${RESET}\n" "$icon" "$cat" >&2
                for tool in ${TOOL_GROUPS[$cat]}; do
                    (( total_tools++ ))
                    if command -v "$tool" &>/dev/null; then
                        (( installed_tools++ ))
                        printf "    ${BGREEN}${ICON_OK}${RESET}  ${GREEN}%-18s${RESET} ${DIM}%s${RESET}\n" \
                            "$tool" "$(command -v "$tool")" >&2
                    else
                        printf "    ${DIM}◦${RESET}  ${DIM}%-18s${RESET}\n" "$tool" >&2
                    fi
                done
            done <<< "$sorted_cats"
            echo -e "" >&2
            printf "  ${DIM}%d / %d tools installed${RESET}  ${DIM}│ devsetup --install TOOL to add${RESET}\n\n" \
                "$installed_tools" "$total_tools" >&2
            ;;

        --dry-run)
            DRY_RUN=true; export DRY_RUN
            log_warn "DRY RUN mode enabled — no changes will be made."
            shift
            if [[ $# -gt 0 ]]; then main "$@"
            else run_interactive
            fi
            ;;

        --install)
            shift
            if [[ $# -eq 0 ]]; then
                log_error "--install requires at least one tool name."
                echo -e "  ${DIM}Usage: devsetup --install docker nginx mysql${RESET}" >&2
                exit 1
            fi
            _print_banner
            log_section "Installing: $*"
            # Run doctor quick checks first
            if ! check_internet 2>/dev/null; then
                log_warn "No internet detected. Installs may fail."
            fi
            install_tool_list "$@"
            ;;

        --update)
            shift
            if [[ $# -eq 0 ]]; then
                log_error "--update requires at least one tool name."
                exit 1
            fi
            _print_banner
            log_section "Updating: $*"
            local tools=("$@"); local total="${#tools[@]}"; local n=0
            _pkg_update
            for tool in "${tools[@]}"; do
                (( n++ ))
                log_progress "$n" "$total" "Updating $tool"
                # Force re-install by removing _already_installed guard temporarily
                local fn="install_${tool,,}"
                if declare -f "$fn" > /dev/null; then
                    # Clear 'already installed' by calling install fn directly
                    # (it checks command -v, but for update we skip that guard)
                    log_step "Re-installing $tool for update..."
                    spinner_start "Updating $tool"
                    local fn_body="_install_${tool,,}_body"
                    if declare -f "$fn_body" > /dev/null; then
                        _do_install "$tool" "$fn_body" || summary_fail "$tool"
                        _installed_ok "$tool updated."
                    else
                        # No dedicated body — just run the installer (idempotent)
                        "$fn" || true
                    fi
                else
                    log_error "No updater for: $tool"
                    summary_fail "$tool (unknown)"
                fi
            done
            echo -e "" >&2
            log_summary
            ;;

        --uninstall)
            shift
            if [[ $# -eq 0 ]]; then
                log_error "--uninstall requires at least one tool name."
                exit 1
            fi
            _print_banner
            log_section "Uninstalling: $*"
            if ! tui_confirm "Remove ${*}? This cannot be undone."; then
                log_skip "Uninstall cancelled."; exit 0
            fi
            local tools=("$@"); local total="${#tools[@]}"; local n=0
            for tool in "${tools[@]}"; do
                (( n++ ))
                log_progress "$n" "$total" "Removing $tool"
                uninstall_tool "$tool" || log_warn "Could not fully remove $tool"
            done
            echo -e "" >&2
            log_summary
            ;;

        --git-config)
            run_git_config_wizard
            ;;

        --aliases)
            inject_aliases "$CONF_DIR/aliases.conf"
            ;;

        --scaffold)
            shift
            local proj_name="${1:-}"
            if [[ -n "$proj_name" ]]; then
                scaffold_project "$CONF_DIR/folders.conf" "$HOME/projects/$proj_name"
            else
                scaffold_interactive "$CONF_DIR/folders.conf"
            fi
            ;;

        --remove-aliases)
            remove_aliases
            ;;

        --preview-aliases)
            preview_aliases "$CONF_DIR/aliases.conf"
            ;;

        --preview-scaffold)
            preview_scaffold "$CONF_DIR/folders.conf"
            ;;

        *)
            log_error "Unknown option: $1"
            echo -e "  ${DIM}Run 'devsetup --help' for usage.${RESET}" >&2
            exit 1
            ;;
    esac
}

main "$@"

    _print_banner
    cat >&2 <<EOF
${BWHITE}${BOLD}USAGE${RESET}
  devsetup [OPTIONS]

${BWHITE}${BOLD}CORE COMMANDS${RESET}
  ${TEAL}(none)${RESET}                     Launch interactive TUI tool selector
  ${TEAL}--install${RESET} TOOL [...]        Install one or more tools
  ${TEAL}--update${RESET}  TOOL [...]        Re-install / update tools to latest
  ${TEAL}--uninstall${RESET} TOOL [...]      Remove tools
  ${TEAL}--status${RESET}                   Show versions of all detected tools
  ${TEAL}--doctor${RESET}                   Pre-flight: internet, sudo, disk, locks


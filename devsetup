#!/usr/bin/env bash
# =============================================================================
#  devsetup вҖ” DevOps Bootstrapper  v1.0.3
#
#  Usage:
#    devsetup                          Interactive TUI tool selector
#    devsetup --install TOOL [...]     Install specific tools
#    devsetup --update  TOOL [...]     Re-install / update tools
#    devsetup --uninstall TOOL [...]   Remove tools
#    devsetup --status                 Show installed versions
#    devsetup --doctor                 Pre-flight system check
#    devsetup --list                   List all available tools
#    devsetup --git-config             Git configuration wizard
#    devsetup --aliases                Inject shell aliases
#    devsetup --scaffold [NAME]        Create project folder structure
#    devsetup --dry-run [CMD...]       Preview without making changes
#    devsetup --help                   Show help
#    devsetup --version                Print version
# =============================================================================
# Never use set -e вҖ” install sub-commands can legitimately return non-zero
set -uo pipefail

# в”Җв”Җ Resolve install location (symlink-safe) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
DEVSETUP_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
LIB_DIR="$DEVSETUP_DIR/lib"
CONF_DIR="$DEVSETUP_DIR/config"

# в”Җв”Җ Source library modules в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
for _lib in logger detect install aliases scaffold tui; do
    # shellcheck source=/dev/null
    source "$LIB_DIR/${_lib}.sh" \
        || { echo "ERROR: cannot load lib/${_lib}.sh вҖ” is devsetup installed correctly?" >&2; exit 1; }
done
unset _lib

# в”Җв”Җ Global flags в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
DRY_RUN="${DRY_RUN:-false}"
export DRY_RUN

DEVSETUP_VERSION="1.0.5"

# в”Җв”Җ Lock file (prevent concurrent runs) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
LOCK_FILE="/tmp/devsetup.lock"

_acquire_lock() {
    exec 9>"$LOCK_FILE"
    if ! flock -n 9 2>/dev/null; then
        echo -e "${BRED}вңҳ  Another devsetup process is already running.${RESET}" >&2
        echo -e "${DIM}   If that's wrong, delete the lock: sudo rm $LOCK_FILE${RESET}" >&2
        exit 1
    fi
}

_release_lock() {
    flock -u 9 2>/dev/null || true
    rm -f "$LOCK_FILE" 2>/dev/null || true
}

# в”Җв”Җ Traps: clean exit + Ctrl+C в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
_on_exit() {
    local rc=$?
    [[ -n "${_SPINNER_PID:-}" ]] && {
        kill "$_SPINNER_PID" 2>/dev/null || true
        wait "$_SPINNER_PID" 2>/dev/null || true
        printf "\r\033[2K" >&2
    }
    _release_lock
    exit $rc
}

_on_abort() {
    # Restore terminal state in case TUI left it raw
    stty sane 2>/dev/null || true
    tput cnorm 2>/dev/null || true
    printf "\r\033[2K" >&2
    echo -e "" >&2
    echo -e "  ${GOLD}${BOLD}вҡ   Aborted (Ctrl+C).${RESET}  ${DIM}Check $LOG_FILE for details.${RESET}" >&2
    echo -e "" >&2
    if (( ${#_SUMMARY_OK[@]} + ${#_SUMMARY_FAIL[@]} + ${#_SUMMARY_SKIP[@]} > 0 )); then
        log_summary
    fi
    _release_lock
    exit 130
}

trap '_on_exit'  EXIT
trap '_on_abort' INT TERM


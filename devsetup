#!/usr/bin/env bash
# =============================================================================
#  devsetup — DevOps Bootstrapper  (production-grade)
#
#  Usage:
#    devsetup                          Interactive TUI mode
#    devsetup --install TOOL [...]     Install specific tools
#    devsetup --update  TOOL [...]     Re-install / update tools
#    devsetup --uninstall TOOL [...]   Remove tools
#    devsetup --status                 Show installed versions
#    devsetup --doctor                 Pre-flight system check
#    devsetup --list                   List all available tools
#    devsetup --git-config             Git configuration wizard
#    devsetup --aliases                Inject shell aliases
#    devsetup --scaffold [NAME]        Create project folder structure
#    devsetup --dry-run [CMD...]       Preview without making changes
#    devsetup --help                   Show help
#    devsetup --version                Print version
# =============================================================================
# Do NOT use set -e — install commands can legitimately fail;
# we handle each explicitly so errors are always visible.
set -uo pipefail

# ── Resolve script location (symlink-safe) ────────────────────────────────────
DEVSETUP_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
LIB_DIR="$DEVSETUP_DIR/lib"
CONF_DIR="$DEVSETUP_DIR/config"

# ── Source library modules ────────────────────────────────────────────────────
for _lib in logger detect install aliases scaffold tui; do
    # shellcheck source=/dev/null
    source "$LIB_DIR/${_lib}.sh" \
        || { echo "ERROR: cannot source lib/${_lib}.sh"; exit 1; }
done

# ── Global flags ──────────────────────────────────────────────────────────────
DRY_RUN="${DRY_RUN:-false}"
export DRY_RUN

DEVSETUP_VERSION="1.1.0"

# ── Lock file (prevent concurrent runs) ──────────────────────────────────────
LOCK_FILE="/tmp/devsetup.lock"
LOCK_FD=9

_acquire_lock() {
    exec 9>"$LOCK_FILE"
    if ! flock -n 9 2>/dev/null; then
        echo -e "${BRED}✘  devsetup is already running (lock: $LOCK_FILE)${RESET}" >&2
        echo -e "${DIM}   If this is wrong, delete the lock: rm $LOCK_FILE${RESET}" >&2
        exit 1
    fi
}

_release_lock() {
    flock -u 9 2>/dev/null || true
    rm -f "$LOCK_FILE" 2>/dev/null || true
}

# ── Signal & exit traps ────────────────────────────────────────────────────────
_on_exit() {
    local rc=$?
    # Kill spinner if orphaned
    if [[ -n "${_SPINNER_PID:-}" ]]; then
        kill "$_SPINNER_PID" 2>/dev/null || true
        wait "$_SPINNER_PID" 2>/dev/null || true
        printf "\r\033[2K" >&2
    fi
    _release_lock
    exit $rc
}

_on_abort() {
    printf "\r\033[2K" >&2
    echo -e "" >&2
    echo -e "  ${GOLD}${BOLD}⚠  Aborted by user (Ctrl+C).${RESET}" >&2
    echo -e "  ${DIM}Partial installs may have occurred. Check: $LOG_FILE${RESET}" >&2
    echo -e "" >&2
    # Print whatever summary we have so far even on abort
    if (( ${#_SUMMARY_OK[@]} + ${#_SUMMARY_FAIL[@]} + ${#_SUMMARY_SKIP[@]} > 0 )); then
        log_summary
    fi
    _release_lock
    # Restore terminal in case TUI was active
    stty sane 2>/dev/null || true
    tput cnorm 2>/dev/null || true
    exit 130
}

trap '_on_exit'  EXIT
trap '_on_abort' INT TERM

